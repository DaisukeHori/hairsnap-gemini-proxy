# --- プロキシサーバー認証 ---
# REVOL Mirror の GEMINI_API_KEY に設定する値
PROXY_API_KEY=hairsnap-your-secret-key-here

# --- バックエンド選択 ---
# "runpod" or "modal"
BACKEND=modal

# --- RunPod Serverless ---
RUNPOD_ENDPOINT_URL=https://api.runpod.ai/v2/your-endpoint-id
RUNPOD_API_KEY=your-runpod-api-key
RUNPOD_TIMEOUT_MS=30000

# --- Modal Serverless ---
MODAL_ENDPOINT_URL=https://your-modal-endpoint.modal.run
MODAL_TIMEOUT_MS=60000
